# Server
PORT=5000
NODE_ENV=production

# Database MySQL (isi dengan kredensial Railway MySQL)
DB_HOST=your_mysql_host
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=carimakan_db
DB_PORT=3306

# JWT Secret (ganti dengan string acak yang panjang)
JWT_SECRET=your_super_secret_jwt_key_here

# URL frontend yang diizinkan (isi setelah frontend di-deploy)
# Contoh: https://carimakan.vercel.app,https://carimakan.netlify.app
ALLOWED_ORIGINS=
